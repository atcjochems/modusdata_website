---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { content } from '../../data/content';
// FIX 1: Import Astro's safe collection loader
import { getEntry } from 'astro:content';

// FIX 2: Fetch the markdown entry safely using Content Collections
const frontpageEntry = await getEntry('pages', 'frontpage');
if (!frontpageEntry) {
  throw new Error('Could not find src/content/pages/frontpage.md');
}

// FIX 3: Render the markdown body to an HTML component tag
const { Content } = await frontpageEntry.render();

if (!content.de) {
  throw new Error('Content for German is not available');
}
const data = content.de;
---
<BaseLayout title={`${data.title} | ${data.subtitle}`} description={data.hero} locale="de" switchUrl="/" langSwitch={data.languageSwitch} nav={data.nav}>
  <section class="hero">
    <p class="hero-subtitle">{data.subtitle}</p>
    <h1>{data.title}</h1>
    <p class="hero-description">{data.hero}</p>
  </section>

  <!-- FIX 4: Render the global markdown copy here via the portal slot -->
  <div class="markdown-content">
    <Content />
  </div>

  <section id="services" class="section">
    <h2>{data.servicesIntro}</h2>
    <ul class="service-list">
      {data.services.map((service) => (
        <li>{service}</li>
      ))}
    </ul>
  </section>

  <section id="about" class="section grid">
    <div class="card">
      <h2>{data.aboutTitle}</h2>
      <p>{data.aboutText}</p>
    </div>
    <div class="card">
      <h2>{data.contactTitle}</h2>
      <div class="contact-card">
        <p>{data.contactText}</p>
        <p class="address">{data.addressLines.join(', ')}</p>
        <a class="contact-email" href={`mailto:${data.email}`}>{data.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Layout Sections --- */
  .hero {
    padding: 4rem 0 3rem 0;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 2rem;
  }
  
  .hero-subtitle {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .hero h1 {
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: #111827;
  }

  .hero-description {
    font-size: 1.25rem;
    line-height: 1.6;
    color: #374151;
    max-width: 42rem;
  }

  .section {
    padding: 3rem 0;
    border-top: 1px solid #e5e7eb;
  }

  .section h2 {
    font-size: 1.75rem;
    font-weight: 600;
    color: #111827;
    margin-bottom: 1.5rem;
  }

  /* --- Lists --- */
  .service-list {
    list-style-type: none;
    padding-left: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .service-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .service-list li {
    position: relative;
    padding-left: 1.5rem;
    line-height: 1.5;
    color: #4b5563;
  }

  .service-list li::before {
    content: "■";
    position: absolute;
    left: 0;
    color: var(--accent-color, #0066cc);
    font-size: 0.75rem;
    top: 0.1rem;
  }

  /* --- Grid & Cards --- */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .card {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 2rem;
  }

  .card p {
    color: #4b5563;
    line-height: 1.6;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .address {
    font-style: normal;
  }

  .contact-email {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
    font-weight: 500;
    width: fit-content;
  }

  .contact-email:hover {
    text-decoration: underline;
  }

  /* --- Markdown Render Engine Core Styles --- */
  .markdown-content {
    margin-bottom: 3rem;
  }

  .markdown-content :global(h1) {
    font-size: 2.25rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
  }
  
  .markdown-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 600;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .markdown-content :global(h3) {
    font-size: 1.35rem;
    font-weight: 600;
    color: #111827;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }
  
  .markdown-content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.65;
    color: #374151;
  }

  .markdown-content :global(a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
    font-weight: 500;
  }

  .markdown-content :global(a:hover) {
    text-decoration: underline;
  }

  .markdown-content :global(blockquote) {
    border-left: 4px solid var(--accent-color, #0066cc);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    background-color: #f9fafb;
  }

  .markdown-content :global(blockquote p) {
    margin-bottom: 0;
    font-style: italic;
    color: #4b5563;
  }

  .markdown-content :global(hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2.5rem 0;
  }
</style>