---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';

const pages = await import.meta.glob('../content/pages/*.md', { eager: true });
const about = pages['../content/pages/about.md'] as any;

// FIX: Extract the default export and assign it to a Capitalized variable 
// so Astro knows to treat and render it as an HTML element component.
const AboutContent = about.default;

const data = content.en;
---

<BaseLayout 
  title={`About | ${data.title}`}
  description="About Arthur Jochems and Modus Data"
>
  <div class="markdown-content">
    <AboutContent />
  </div>
</BaseLayout>

<style>
  /* --- Cleaned up styles (removed the duplicate global block) --- */
  :global(.markdown-content h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(.markdown-content p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(.markdown-content ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content li) {
    margin-bottom: 0.5rem;
  }

  :global(.markdown-content a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(.markdown-content a:hover) {
    text-decoration: underline;
  }

  :global(.markdown-content img) {
    max-width: 100%;
    height: auto;
    margin: 1rem 0;
  }
</style>