---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';
import { getCollection } from 'astro:content';

const data = content.en;
const pages = await getCollection('pages');
const page = pages.find(p => p.id === 'about');
const { Content } = page ? await page.render() : { Content: null };
---

<BaseLayout 
  title={data.nav.about + ' | ' + data.title}
  description="About Arthur Jochems and Modus Data"
  locale="en" 
  switchUrl="/de/about/" 
  langSwitch={data.languageSwitch}
  nav={data.nav}
>
  {Content ? <Content /> : null}
</BaseLayout>

<style>
  :global(h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(li) {
    margin-bottom: 0.5rem;
  }

  :global(a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }

  :global(img) {
    max-width: 100%;
    height: auto;
    margin: 1rem 0;
  }
</style>

<style>
  :global(.markdown-content h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(.markdown-content p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(.markdown-content ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content li) {
    margin-bottom: 0.5rem;
  }

  :global(.markdown-content a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(.markdown-content a:hover) {
    text-decoration: underline;
  }

  :global(.markdown-content img) {
    max-width: 100%;
    height: auto;
    margin: 1rem 0;
  }
</style>
