---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';
import { getEntry } from 'astro:content';

const servicesEntry = await getEntry('pages', 'services');
if (!servicesEntry) throw new Error('Could not find services markdown');
const { Content } = await servicesEntry.render();

const data = content.en; // Use content.de for German subpages
---
<BaseLayout title={`${data.nav.services} | Modus Data`} locale="en" switchUrl="/de/services/" langSwitch={data.languageSwitch} nav={data.nav}>
  <div class="markdown-content">
    <Content />
  </div>
</BaseLayout>

