---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';

const pages = await import.meta.glob('../content/pages/*.md', { eager: true });
const services = pages['../content/pages/services.md'] as any;

// FIX: Assign the component factory to a Capitalized variable name
const ServicesContent = services.default;

const data = content.en;
---

<BaseLayout 
  title={data.nav.services + ' | ' + data.title}
  description="Our AI and machine learning services"
  locale="en" 
  switchUrl="/de/services/" 
  langSwitch={data.languageSwitch}
  nav={data.nav}
>
  <div class="markdown-content">
    <!-- FIX: Render it as a proper element tag instead of using set:html -->
    <ServicesContent />
  </div>
</BaseLayout>

<style>
  :global(h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(li) {
    margin-bottom: 0.5rem;
  }

  :global(a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }
</style>

<style>
  :global(.markdown-content h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(.markdown-content p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(.markdown-content ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content li) {
    margin-bottom: 0.5rem;
  }

  :global(.markdown-content a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(.markdown-content a:hover) {
    text-decoration: underline;
  }
</style>