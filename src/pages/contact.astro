---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const contactEntry = await getEntry('pages', 'contact');
if (!contactEntry) throw new Error('Could not find contact markdown');

const { Content } = await contactEntry.render();

const title = "Contact | Modus Data";
---

<BaseLayout 
  title={title}
  description="Contact Modus Data for expert AI consulting and data science services in Switzerland."
>
  <div class="markdown-content contact-page">
    <Content />
  </div>
</BaseLayout>

