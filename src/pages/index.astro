---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';

const pages = await import.meta.glob('../content/pages/*.md', { eager: true });
const frontpage = pages['../content/pages/frontpage.md'] as any;

const data = content.en;
---
<BaseLayout title={`${data.title} | ${data.subtitle}`} description={data.hero} locale="en" switchUrl="/de/" langSwitch={data.languageSwitch} nav={data.nav}>
  <div set:html={frontpage.default} />
</BaseLayout>

<style>
  :global(h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(li) {
    margin-bottom: 0.5rem;
  }

  :global(a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }

  :global(blockquote) {
    border-left: 4px solid var(--accent-color, #0066cc);
    margin-left: 0;
    margin-bottom: 1rem;
    padding-left: 1rem;
    font-style: italic;
  }

  :global(hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
</style>

<style>
  :global(.markdown-content h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(.markdown-content p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(.markdown-content ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(.markdown-content li) {
    margin-bottom: 0.5rem;
  }

  :global(.markdown-content a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(.markdown-content a:hover) {
    text-decoration: underline;
  }

  :global(.markdown-content blockquote) {
    border-left: 4px solid var(--accent-color, #0066cc);
    margin-left: 0;
    margin-bottom: 1rem;
    padding-left: 1rem;
    font-style: italic;
  }

  :global(.markdown-content hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
</style>
