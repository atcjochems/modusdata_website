---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';
// Import Astro's safe collection loader
import { getEntry } from 'astro:content';

// 1. Fetch the markdown data safely using Astro Content Collections
const frontpageEntry = await getEntry('pages', 'frontpage');
if (!frontpageEntry) {
  throw new Error('Could not find src/content/pages/frontpage.md');
}

// 2. Render the markdown body to HTML component text
const { Content } = await frontpageEntry.render();

// 3. Setup your language dictionary data
if (!content.en) {
  throw new Error('Content for English is not available');
}
// FIX 1: Point to content.en so the header/footer text loads in English
const data = content.en;
---
<!-- FIX 2 & 3: Updated locale to "en" and switchUrl to forward to your German index "/de/" -->
<BaseLayout title={`${data.title} | ${data.subtitle}`} description={data.hero} locale="en" switchUrl="/de/" langSwitch={data.languageSwitch} nav={data.nav}>
  <div class="markdown-content">
    <Content />
  </div>
</BaseLayout>

<style>
  :global(h1) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  :global(h2) {
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  :global(p) {
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  :global(ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  
  :global(li) {
    margin-bottom: 0.5rem;
  }

  :global(a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }

  :global(blockquote) {
    border-left: 4px solid var(--accent-color, #0066cc);
    margin-left: 0;
    margin-bottom: 1rem;
    padding-left: 1rem;
    font-style: italic;
  }

  :global(hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
</style>

