---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';
import { getEntry } from 'astro:content';

const frontpageEntry = await getEntry('pages', 'frontpage');
if (!frontpageEntry) {
  throw new Error('Could not find src/content/pages/frontpage.md');
}

const { Content } = await frontpageEntry.render();

if (!content.en) {
  throw new Error('Content for English is not available');
}

const data = content.en;
import Testimonials from '../components/widgets/Testimonials.astro';
import FAQ from '../components/widgets/FAQ.astro';
---

<BaseLayout title={`${data.title} | ${data.subtitle}`} description={data.hero}>
  <section class="hero-panel demo">
    <h1>{data.title}</h1>
    <p>{data.hero}</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/services/">Explore services</a>
      <a class="btn btn-secondary" href="mailto:arthur@modusdata.ch">Book a consultation</a>
    </div>
  </section>

  <div class="markdown-content">
    <Content />
  </div>

  <!-- Testimonials and FAQ removed to match demo layout -->
</BaseLayout>