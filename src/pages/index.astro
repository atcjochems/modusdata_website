---
import BaseLayout from '../layouts/BaseLayout.astro';
import { content } from '../data/content';
// Import Astro's safe collection loader
import { getEntry } from 'astro:content';

// 1. Fetch the markdown data safely using Astro Content Collections
const frontpageEntry = await getEntry('pages', 'frontpage');
if (!frontpageEntry) {
  throw new Error('Could not find src/content/pages/frontpage.md');
}

// 2. Render the markdown body to HTML component text
const { Content } = await frontpageEntry.render();

// 3. Setup your language dictionary data
if (!content.en) {
  throw new Error('Content for English is not available');
}
// Point to content.en so the header/footer text loads in English
const data = content.en;
---
<!-- Updated locale to "en" and switchUrl to forward to your German index "/de/" -->
<BaseLayout title={`${data.title} | ${data.subtitle}`} description={data.hero} locale="en" switchUrl="/de/" langSwitch={data.languageSwitch} nav={data.nav}>
  <div class="markdown-content">
    <Content />
  </div>
</BaseLayout>

<style>
  /* --- Markdown Render Engine Core Styles --- */
  .markdown-content {
    margin: 2rem 0 4rem 0;
  }

  /* Target headers generated dynamically inside the markdown block wrapper */
  .markdown-content :global(h1) {
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.2;
    color: #111827;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }
  
  .markdown-content :global(h2) {
    font-size: 1.85rem;
    font-weight: 600;
    color: #111827;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
  }
  
  .markdown-content :global(h3) {
    font-size: 1.4rem;
    font-weight: 600;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  
  .markdown-content :global(p) {
    font-size: 1.125rem;
    line-height: 1.65;
    color: #374151;
    margin-bottom: 1.5rem;
    max-width: 44rem; /* Keeps reading line length optimized */
  }

  .markdown-content :global(ul) {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .markdown-content :global(li) {
    font-size: 1.125rem;
    line-height: 1.6;
    color: #4b5563;
    margin-bottom: 0.5rem;
  }

  .markdown-content :global(a) {
    color: var(--accent-color, #0066cc);
    text-decoration: none;
    font-weight: 500;
  }

  .markdown-content :global(a:hover) {
    text-decoration: underline;
  }

  .markdown-content :global(blockquote) {
    border-left: 4px solid var(--accent-color, #0066cc);
    margin: 2rem 0;
    padding: 0.75rem 0 0.75rem 1.5rem;
    background-color: #f9fafb;
    border-radius: 0 4px 4px 0;
  }

  .markdown-content :global(blockquote p) {
    margin-bottom: 0;
    font-style: italic;
    color: #4b5563;
  }

  .markdown-content :global(hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 3rem 0;
  }
</style>