// 1. IMPORT THE GLOBAL CSS DIRECTLY IN THE FRONTMATTER
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description}>}
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="page-shell">
    <header class="site-header">
      <a class="brand" href="/">
        <img class="logo" src="/img/MD_logo.png" alt="Modus Data logo">
        <div>
          <strong>Modus Data</strong>
          <span>Therwil · Switzerland</span>
        </div>
      </a>
      <nav class="site-nav">
        <a href="/services/">Services</a>
        <a href="/about/">About</a>
        <a href="/#about">Contact</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© 2026 Modus Data — Benkenstrasse 3, 4106 Therwil</p>
    </footer>
  </div>
</body>
</html>

<style>
  /* Alignment styling for the language switcher link */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem; /* Space between flag and text */
    text-decoration: none;
    font-weight: 500;
    color: #374151;
    padding: 0.375rem 0.75rem;
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .lang-switch:hover {
    background-color: #f3f4f6;
    color: var(--accent-color, #0066cc);
  }

  /* Flag standard shape configuration */
  .flag-icon {
    border-radius: 2px; /* Subtle soft corner rounding */
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15); /* Gives thin contrast depth on white backgrounds */
    flex-shrink: 0;
  }
</style>